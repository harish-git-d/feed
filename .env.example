# Database Configuration Template
# Copy this file to .env and update with actual values

# Application Database (Read-Only Access)
DB_URL=jdbc:oracle:thin:@hostname:1521:servicename
DB_USERNAME=gai_user
DB_PASSWORD=changeme

# GAI Feed Configuration
GAI_SOURCE_SYSTEM_CSI=SCEF
GAI_SOURCE_SYSTEM_NAME=SCEF
GAI_APP_SHORT_NAME=SCEF
GAI_REGION_INSTANCE=NA
GAI_SOURCE_INDICATOR=S
GAI_FREQUENCY=D
GAI_FILE_TYPE_INDICATOR=F
GAI_OUTPUT_DIR=/path/to/output
GAI_GZIP_ENABLED=true

# SFTP Configuration
GAI_SFTP_ENABLED=false
GAI_SFTP_HOST=sftp.example.com
GAI_SFTP_PORT=22
GAI_SFTP_USERNAME=sftp_user
GAI_SFTP_PASSWORD=changeme
GAI_SFTP_REMOTE_DIR=/upload

# Job Parameters
GAI_FEED_NAME=pse-exposure
GAI_COB_DATE=2026-04-23
GAI_FILE_TIMESTAMP=20260423120000